{
	"luci-app-daed": {
		"description": "Grant access to daed configuration",
		"read": {
			"file": {
				"/var/log/daed/daed.log": [ "read" ],
				"/usr/share/v2ray/geoip.dat": [ "read" ],
				"/usr/share/v2ray/geosite.dat": [ "read" ],
				"/sys/kernel/btf/vmlinux": [ "read" ],
				"/run/netns/daens": [ "read" ],
				"/etc/init.d/daed status": [ "exec" ]
			},
			"ubus": {
				"service": [ "list" ]
			},
			"uci": [ "daed" ]
		},
		"write": {
			"file": {
				"/var/log/daed/daed.log": [ "write" ],
				"/etc/init.d/daed start": [ "exec" ],
				"/etc/init.d/daed stop": [ "exec" ],
				"/etc/init.d/daed restart": [ "exec" ],
				"/etc/init.d/daed enable": [ "exec" ],
				"/etc/init.d/daed disable": [ "exec" ],
				"/sbin/uci set daed.config.enabled=*": [ "exec" ],
				"/sbin/uci commit daed": [ "exec" ],
				"/sbin/ip netns del daens": [ "exec" ]
			},
			"uci": [ "daed" ]
		}
	}
}
